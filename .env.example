# Your custom API key - clients must send this in Authorization: Bearer <key>
DUCK_AI_API_KEY=change-me-to-a-long-random-string

# Server config
HOST=0.0.0.0
PORT=8788

# Default model when client doesn't specify (gpt-4o-mini | claude-3-haiku | llama | mistral | gemini | openai)
DEFAULT_MODEL=gpt-4o-mini

# Backend priority order (comma-separated). Tried in order; first one that succeeds wins.
# Options: duckduckgo, pollinations
BACKEND_ORDER=duckduckgo,pollinations

# Optional HTTP/SOCKS proxy for DuckDuckGo (helps if your server IP gets rate-limited)
# Example: socks5://user:pass@host:port  or  http://host:port
DUCK_PROXY=
